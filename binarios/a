#!/usr/bin/env zsh

# Define el directorio donde se buscarán los archivos.
search_directory="/path/to/your/directory"

# Define la cadena que quieres buscar.
search_string="Kernel IP"

# Comienza el bucle para iterar a través de cada archivo en el directorio.
for file in $search_directory/*; do
  # Usa grep para buscar la cadena. Si se encuentra, ejecuta el comando deseado.
  grep "$search_string" "$file" &> /dev/null
  if [ $? -eq 0 ]; then
    # El comando que quieres ejecutar si se encuentra la cadena.
    # Reemplaza 'your_command' con el comando real que quieres ejecutar.
    your_command
  fi
done

