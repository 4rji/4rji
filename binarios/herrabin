#!/bin/bash
# Función para verificar si un paquete está instalado

paquetes=("curl" "git" "kitty" "nano" "sudo" "zsh" "xclip")

paquete_instalado() {  
    dpkg -l "$1" | grep -q '^ii'  
}

for paquete in "${paquetes[@]}"; do
    if ! paquete_instalado "$paquete"; then  
        sudo apt-get install -y "$paquete"  
    fi  
done





